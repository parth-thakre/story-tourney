PORT=3001
DB_PATH=./data/story-tourney.sqlite

# OpenRouter is the default live provider. If OPENROUTER_API_KEY is omitted,
# the backend falls back to deterministic mock outputs.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

SONNET_MODEL_ID=anthropic/claude-sonnet-4.6
SONNET_PROVIDER_ORDER=google-vertex/us-east5
GPT_MODEL_ID=openai/gpt-5.4
GPT_PROVIDER_ORDER=azure
GLM5_MODEL_ID=zai-org/glm-5
GLM5_PROVIDER_ORDER=venice/fp8
KIMI_K25_MODEL_ID=moonshotai/kimi-k2.5
KIMI_K25_PROVIDER_ORDER=groq

SONNET_SITE_URL=
SONNET_APP_NAME=
GPT_SITE_URL=
GPT_APP_NAME=
GLM5_SITE_URL=
GLM5_APP_NAME=
KIMI_K25_SITE_URL=
KIMI_K25_APP_NAME=
